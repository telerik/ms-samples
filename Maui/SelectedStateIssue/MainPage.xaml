<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SelectedStateIssue"
             x:Class="SelectedStateIssue.MainPage"
             Title="SelectedState Bug Repro">

    <!--
        Repro for: VisualElement.ChangeVisualState() gets stuck in Selected state.

        Steps:
          1. Tap "Select"   - the box turns green (Selected state). ✅
          2. Tap "Deselect" - expected: box turns grey (Normal state).
                              actual:   box stays green (stuck in Selected). ❌

        Root cause:
          VisualElement.ChangeVisualState() calls the internal extension method
          IsElementInSelectedState(), which reads the current VSM group's CurrentState.
          Because the group is still reporting "Selected", the base re-applies it
          even though IsSelected is now false.
    -->

    <VerticalStackLayout Padding="24" Spacing="16">

        <Label Text="SelectableBox — VSM Selected state repro"
               FontAttributes="Bold" FontSize="16" />

        <!-- The custom control under test -->
        <local:SelectableBox x:Name="TheBox"
                             HeightRequest="100" WidthRequest="200"
                             HorizontalOptions="Center" />

        <Label x:Name="StatusLabel"
               HorizontalOptions="Center"
               FontSize="14" />

        <HorizontalStackLayout HorizontalOptions="Center" Spacing="12">
            <Button Text="Select"   Clicked="OnSelectClicked" />
            <Button Text="Deselect" Clicked="OnDeselectClicked" />
        </HorizontalStackLayout>

        <Label Text="Expected after Deselect: grey box (Normal state)"
               FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
        <Label Text="Actual on .NET 10:       green box (stuck in Selected)"
               FontSize="12" TextColor="Red"  HorizontalOptions="Center" />

    </VerticalStackLayout>

</ContentPage>
